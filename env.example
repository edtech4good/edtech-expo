# Environment Configuration Example
# Copy this file to .env and update with your actual values

# Environment type (Staging, Production, Development)
EXPO_PUBLIC_ENV=Staging

# Access type (online, offline)
EXPO_PUBLIC_ACCESS_TYPE=online

# Base URL for the main API server
# Replace with your actual API server URL
EXPO_PUBLIC_BASE_URL=https://your-api-server.com

# Sync URL for data synchronization
# Replace with your actual sync server URL
EXPO_PUBLIC_SYNC_URL=https://your-sync-server.com

# Resource URL for static assets (images, videos, etc.)
# Replace with your actual resource server URL
EXPO_PUBLIC_RESOURCE_URL=https://your-resource-server.com

# Resource path for organizing assets
# Replace with your actual resource path
EXPO_PUBLIC_RESOURCE_PATH=your-resource-path%
