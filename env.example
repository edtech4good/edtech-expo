# Copy to `.env` and adjust. After any change: stop Metro, then `npx expo start -c`
# (Expo bakes EXPO_PUBLIC_* at bundle time — a stale bundle keeps old URLs).

# --- Local Lane C (Expo web + Pi on 3001 + central on 3000) — see ../LOCAL_DEVELOPMENT.md ---
EXPO_PUBLIC_ENV=Development
EXPO_PUBLIC_ACCESS_TYPE=online
EXPO_PUBLIC_BASE_URL=http://127.0.0.1:3001
EXPO_PUBLIC_SYNC_URL=http://127.0.0.1:3000
EXPO_PUBLIC_RESOURCE_URL=https://example.com
EXPO_PUBLIC_RESOURCE_PATH=

# --- Staging / production (uncomment and replace localhost) ---
# EXPO_PUBLIC_ENV=Staging
# EXPO_PUBLIC_BASE_URL=https://your-pi-or-classroom-api.example.com
# EXPO_PUBLIC_SYNC_URL=https://your-central-lms-api.example.com
# EXPO_PUBLIC_RESOURCE_URL=https://your-cdn.example.com
# EXPO_PUBLIC_RESOURCE_PATH=optional-prefix
