{
  "name": "expo_edtech",
  "version": "1.0.0",
  "main": "./index.js",
  "scripts": {
    "start": "npx expo start -c",
    "android": "npx expo start --android",
    "ios": "npx expo start --ios",
    "web": "npx expo start -c",
    "run:prod": "NODE_ENV=prod npx expo start -c",
    "run:staging": "NODE_ENV=test npx expo start -c",
    "build:android:staging": "eas build -p android --profile preview --local",
    "build:android:prod": "eas build -p android --profile prod --local",
    "build:web": "expo export -p web",
    "predeploy": "expo export -p web",
    "select:prod": "firebase target:apply hosting prod your-firebase-project-id",
    "deploy:prod": "NODE_ENV=prod yarn build:web && yarn select:prod && firebase deploy --only hosting:prod",
    "select:staging": "firebase target:apply hosting staging your-staging-target",
    "deploy:staging": "NODE_ENV=test yarn build:web && yarn select:staging && firebase deploy --only hosting:staging"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "1.21.0",
